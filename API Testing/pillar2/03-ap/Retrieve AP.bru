meta {
  name: Retrieve Accounting Period(s)
  type: http
  seq: 1
}

get {
  url: {{pillar2Url}}/subscription/v2/read-subscription/{{testPlrId}}
  body: json
  auth: none
}

headers {
  X-Pillar2-Id: {{testPlrId}}
  Authorization: {{bearer_token}}
}

tests {
  test("Status code is 200", function() {
    expect(res.getStatus()).to.equal(200)
  });
}
