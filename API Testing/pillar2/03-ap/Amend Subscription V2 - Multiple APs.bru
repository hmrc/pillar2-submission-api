meta {
  name: Amend Subscription V2 - Multiple APs
  type: http
  seq: 3
}

put {
  url: {{pillar2Url}}/subscription/v2/amend-subscription/{{testPlrId}}
  body: json
  auth: none
}

headers {
  Content-Type: application/json
  Authorization: {{bearer_token}}
}

body:json {
  {
    "replaceFilingMember": false,
